# --------------------------------------------------
# AI Provider
# --------------------------------------------------

# auto | gemini | openai
AI_PROVIDER=auto

# Google AI Studio key (usually starts with AIza)
GOOGLE_API_KEY=

GEMINI_MODEL=gemini-2.5-flash

# OpenAI key (usually starts with sk-)
OPENAI_API_KEY=

OPENAI_MODEL=gpt-5.5

# --------------------------------------------------
# Authentication
# --------------------------------------------------

# on (default) | off — disable for single-operator local demos
RACKMIND_AUTH=on

# Password for the bootstrap admin account on first run.
# Defaults to "rackmind" — change it immediately either way.
RACKMIND_ADMIN_PASSWORD=

# --------------------------------------------------
# Storage
# --------------------------------------------------

# Override the SQLite database location (incidents, telemetry, users).
# Defaults to data/rackmind.db
RACKMIND_DB=
